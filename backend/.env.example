# ─── Narmavya Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values. NEVER commit .env to git.

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Clusters → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/narmavya?retryWrites=true&w=majority

# JWT Secret — a long random string, used to sign auth tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT expiry
JWT_EXPIRES_IN=7d

# Razorpay Test Keys (from https://dashboard.razorpay.com → Settings → API Keys → Test Mode)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret

# Firebase Admin SDK Service Account JSON path
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Frontend origin (for CORS) — change to your deployed URL in production
CLIENT_ORIGIN=http://localhost:5173

# Port
PORT=5000
